# APP_BASE=
# DB_HOST=localhost
# DB_NAME=u123456789_docu
# DB_USER=u123456789_user
# DB_PASS=your_hostinger_db_password

# ── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=docu_request
DB_USER=root
DB_PASS=

# ── Brevo (email OTP) ───────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SMTP_KEY=your_brevo_smtp_key_here
MAIL_FROM=your@email.com
MAIL_FROM_NAME=Document Request
